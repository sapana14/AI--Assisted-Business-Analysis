# Logic

def analyze_business(notes,question,temperature):
    client = OpenAI(
    api_key="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"
    )
    prompt = f"""
    You are working as a Business Analyst Intern at a mid-sized digital commerce company. The management
    team receives raw operational updates from multiple departments, but these updates are often unstructured
    and difficult to analyze quickly. Your responsibility is to use the AI Business Analyst Assistant to ask relevant
    business questions, interpret AI-generated insights, identify risks and missing data, and support
    management decision-making.
    Given the following business data 
    {notes}

    Explain This Terms

    A. Business Understanding
    B. Decision Support
    C. Missing Data Analysis
    D. Critical Thinking & Risk Awareness

    User Question
    {question}

    Guidelines
    - Answer clearly and practically
    - Do NOT assume missing data
    - If information is insufficient, explicitly say what is missing
    - Keep business language simple and actionable
    """

    response = client.chat.completions.create(
        model='gpt-4o-mini',
        messages=[
            {"role": "system", "content": "You are a careful, practical business analyst."},
            {"role": "user", "content": prompt}
        ],
        temperature=temperature
    )

    return response.choices[0].message.content


